# GEMINI_API_KEY: usada SOLO por el servidor (funcion serverless en Vercel,
# o server/dev-server.ts en desarrollo local). Nunca se expone al navegador.
# Consiguela gratis en https://aistudio.google.com/
GEMINI_API_KEY="tu-api-key-aqui"

# API_PORT: puerto donde corre el servidor local de desarrollo (server/dev-server.ts).
# Opcional, por defecto 8787.
API_PORT=8787
